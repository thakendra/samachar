<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Since Android Network Security Config <domain> does not support raw IP addresses,
         and our backend is currently hosted on a raw public IP (http://72.60.203.57/),
         we must permit cleartext traffic app-wide in the base configuration. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
